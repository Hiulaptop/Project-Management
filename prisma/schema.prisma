// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPERUSER
  ADMIN
  USER
}

enum ProjectRole {
  OWNER
  MANAGER
  MEMBER
}

enum DeadlineStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum ColleagueStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  password     String
  fullname     String
  phone_number String  @unique
  role         UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RBAC & PROJECT
  ownedProjects   Project[]          @relation("ProjectOwner")
  projectMembers  Project_members[]
  deadlinesSet    Deadlines[]         @relation("DeadlineSetter")
  deadlineAssigns Deadline_assignees[]

  // COLLEAGUES
  colleaguesSent     UserColleague[] @relation("ColleagueSender")
  colleaguesReceived UserColleague[] @relation("ColleagueReceiver")
}

model UserColleague {
  sender    User   @relation("ColleagueSender", fields: [sender_id], references: [id], onDelete: Cascade)
  sender_id String

  receiver    User   @relation("ColleagueReceiver", fields: [receiver_id], references: [id], onDelete: Cascade)
  receiver_id String

  status    ColleagueStatus @default(PENDING)
  createdAt DateTime        @default(now())

  @@id([sender_id, receiver_id])
  @@index([receiver_id])
}

model Project {
  id       BigInt @id @default(autoincrement())
  owner    User   @relation("ProjectOwner", fields: [owner_id], references: [id])
  owner_id String

  title       String
  description String?   @db.Text
  start_date  DateTime
  end_date    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   Project_members[]
  deadlines Deadlines[]

  @@index([owner_id])
}

model Project_members {
  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id BigInt

  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String

  role_in_project ProjectRole @default(MEMBER)
  join_at         DateTime    @default(now())

  @@id([project_id, user_id])
  @@index([user_id])
}

model Deadline_assignees {
  deadline    Deadlines @relation(fields: [deadline_id], references: [id], onDelete: Cascade)
  deadline_id BigInt

  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String

  assigned_at DateTime @default(now())

  @@id([deadline_id, user_id])
  @@index([user_id])
}

model Deadlines {
  id BigInt @id @default(autoincrement())

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id BigInt

  setter    User   @relation("DeadlineSetter", fields: [setter_id], references: [id])
  setter_id String

  title         String
  description   String?        @db.Text
  deadline_date DateTime
  status        DeadlineStatus @default(TODO)
  feedback      String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignees Deadline_assignees[]

  @@index([project_id])
  @@index([deadline_date])
}
